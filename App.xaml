<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Greenhouse_Control.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Greenhouse_Control"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="White" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#CCFFFFFF" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#99FFFFFF" />
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
